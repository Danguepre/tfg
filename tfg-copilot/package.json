{
  "name": "tfg-copilot",
  "private": true,
  "scripts": {
    "test": "npm run test:backend && npm run test:frontend && npm run test:e2e",
    "test:backend": "python -m unittest tests.test_api",
    "test:frontend": "powershell -NoProfile -Command \"Set-Location frontend; npm.cmd run test\"",
    "test:e2e": "python -m unittest discover -s tests/e2e -p \"test_*.py\"",
    "lint": "powershell -NoProfile -Command \"Set-Location frontend; npm.cmd run lint\""
  }
}
